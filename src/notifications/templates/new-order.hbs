<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <style>
    body { font-family: Arial, sans-serif; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    h2 { color: #e63946; }
    table { width: 100%; border-collapse: collapse; margin-top: 16px; }
    th { background: #e63946; color: #fff; padding: 8px; text-align: left; }
    td { padding: 8px; border-bottom: 1px solid #ddd; }
    .total { font-weight: bold; font-size: 1.1em; }
  </style>
</head>
<body>
  <div class="container">
    <h2>🛒 Nuevo pedido recibido</h2>
    <p><strong>Negocio:</strong> {{businessName}}</p>
    <p><strong>Cliente:</strong> {{customerName}}</p>
    <p><strong>Teléfono:</strong> {{phone}}</p>
    {{#if email}}<p><strong>Email:</strong> {{email}}</p>{{/if}}
    <p><strong>Fecha de entrega:</strong> {{deliveryDate}}</p>
    {{#if notes}}<p><strong>Notas:</strong> {{notes}}</p>{{/if}}

    <table>
      <thead>
        <tr>
          <th>Producto</th>
          <th>Cant.</th>
          <th>Precio unit.</th>
          <th>Subtotal</th>
        </tr>
      </thead>
      <tbody>
        {{#each items}}
        <tr>
          <td>{{this.productNameSnapshot}}</td>
          <td>{{this.quantity}}</td>
          <td>${{this.unitPrice}}</td>
          <td>${{this.subtotal}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <p class="total" style="margin-top:16px;">Total: ${{total}}</p>
    <hr />
    <p style="color:#999;font-size:12px;">Pedido recibido el {{createdAt}}</p>
  </div>
</body>
</html>
